.DS_Store

# Build directories.
build/
dist/
*.egg-info/
.eggs/


# Python
# Compiled source
__pycache__/
*.pyc
# The .python-version file is often specific to a local environment
.python-version 

# Environments
.env
venv/
env/
# Poetry
.venv

# Editor-specific
.vscode/
.idea/

# Unit test and coverage
htmlcov/
.tox/
.coverage
.coverage.*
nosetests.xml
coverage.xml
*,cover

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# MATLAB
# Remove autosaves generated by the Matlab editor
# Windows default autosave extension
*.asv
# OSX / *nix default autosave extension
*.m~
*.autosave

# Compiled MEX binaries (all platforms)
*.mex*

# Derived content-obscured files
*.p

# Simulink Code Generation folders
slprj/
sccprj/
codegen/

# Session info
octave-workspace

# Packaged app and toolbox files
*.mlappinstall
*.mltbx

# Deployable archives
*.ctf

# Generated helpsearch folders
helpsearch*/

# MATLAB Coder/GPU Coder/Embedded Coder
_codegen/
